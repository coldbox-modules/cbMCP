<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>ColdBox MCP Server</title>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
	<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
	<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
	<style>
		:root {
			--boxlang-night: #041319;
			--boxlang-void: #07202b;
			--boxlang-surface: rgba(7, 32, 43, 0.82);
			--boxlang-surface-strong: rgba(8, 39, 52, 0.94);
			--boxlang-border: rgba(0, 219, 255, 0.24);
			--boxlang-border-strong: rgba(0, 255, 117, 0.34);
			--boxlang-primary: #00dbff;
			--boxlang-secondary: #00ff75;
			--boxlang-glow: #85ffe3;
			--boxlang-text: #f3fffb;
			--boxlang-text-muted: rgba(230, 255, 248, 0.74);
			--boxlang-shadow: rgba(0, 0, 0, 0.32);
		}

		[x-cloak] {
			display: none !important;
		}

		body {
			background:
				radial-gradient(circle at top left, rgba(0, 219, 255, 0.18), transparent 28%),
				radial-gradient(circle at 85% 18%, rgba(0, 255, 117, 0.16), transparent 24%),
				linear-gradient(135deg, var(--boxlang-night) 0%, #052430 48%, var(--boxlang-void) 100%);
			min-height: 100vh;
			color: var(--boxlang-text);
			position: relative;
		}

		body::before {
			content: "";
			position: fixed;
			inset: 0;
			background-image:
				linear-gradient(rgba(255, 255, 255, 0.018) 1px, transparent 1px),
				linear-gradient(90deg, rgba(255, 255, 255, 0.018) 1px, transparent 1px);
			background-size: 28px 28px;
			opacity: 0.25;
			pointer-events: none;
		}

		.container-fluid,
		.navbar {
			position: relative;
			z-index: 1;
		}

		.navbar {
			background-color: rgba(4, 19, 25, 0.88) !important;
			backdrop-filter: blur(10px);
			border-bottom: 1px solid var(--boxlang-border);
			box-shadow: 0 14px 34px rgba(0, 0, 0, 0.22);
		}

		.navbar-brand {
			display: flex;
			align-items: center;
			gap: 0.9rem;
			font-weight: 700;
			font-size: 1.15rem;
			text-decoration: none;
		}

		.navbar-brand img {
			height: 2.5rem;
			width: auto;
			filter: drop-shadow(0 0 16px rgba(0, 219, 255, 0.2));
		}

		.brand-copy {
			display: flex;
			flex-direction: column;
			line-height: 1.05;
		}

		.brand-copy strong {
			font-size: 1rem;
			background: linear-gradient(90deg, #ffffff, var(--boxlang-primary), var(--boxlang-secondary));
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
			background-clip: text;
		}

		.brand-copy small {
			color: var(--boxlang-text-muted);
			font-size: 0.73rem;
			letter-spacing: 0.08em;
			text-transform: uppercase;
		}

		.welcome-section {
			background:
				linear-gradient(145deg, rgba(0, 219, 255, 0.1), rgba(0, 255, 117, 0.06)),
				var(--boxlang-surface);
			border: 1px solid var(--boxlang-border);
			border-radius: 24px;
			padding: 3rem;
			margin-bottom: 2rem;
			box-shadow: 0 24px 60px var(--boxlang-shadow);
			overflow: hidden;
			position: relative;
		}

		.welcome-section::after {
			content: "";
			position: absolute;
			width: 20rem;
			height: 20rem;
			right: -7rem;
			top: -8rem;
			background: radial-gradient(circle, rgba(0, 219, 255, 0.2) 0%, rgba(0, 219, 255, 0) 68%);
			pointer-events: none;
		}

		.hero-grid {
			display: grid;
			grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 0.8fr);
			gap: 2rem;
			align-items: center;
		}

		.hero-logo-panel {
			display: flex;
			justify-content: center;
			align-items: center;
			background: linear-gradient(160deg, rgba(255, 255, 255, 0.04), rgba(0, 219, 255, 0.09));
			border: 1px solid rgba(255, 255, 255, 0.08);
			border-radius: 24px;
			padding: 2rem;
			min-height: 100%;
		}

		.hero-logo {
			width: min(100%, 24rem);
			height: auto;
			filter: drop-shadow(0 0 30px rgba(0, 219, 255, 0.22));
		}

		.hero-badge {
			display: inline-flex;
			align-items: center;
			gap: 0.55rem;
			padding: 0.55rem 0.95rem;
			border: 1px solid rgba(0, 255, 117, 0.22);
			border-radius: 999px;
			background: rgba(0, 255, 117, 0.08);
			color: var(--boxlang-glow);
			font-size: 0.85rem;
			font-weight: 600;
			letter-spacing: 0.02em;
			margin-bottom: 1rem;
		}

		.welcome-section h1 {
			background: linear-gradient(90deg, #ffffff 0%, var(--boxlang-primary) 45%, var(--boxlang-secondary) 100%);
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
			background-clip: text;
			font-weight: 700;
			line-height: 1.05;
			max-width: 12ch;
		}

		.lead {
			color: var(--boxlang-text);
		}

		.text-muted {
			color: var(--boxlang-text-muted) !important;
		}

		.card {
			background: var(--boxlang-surface);
			border: 1px solid var(--boxlang-border);
			border-radius: 24px;
			box-shadow: 0 18px 48px rgba(0, 0, 0, 0.18);
			transition: all 0.3s ease;
			backdrop-filter: blur(10px);
		}

		.card:hover {
			transform: translateY(-4px);
			box-shadow: 0 24px 56px rgba(0, 0, 0, 0.24);
		}

		.card-header {
			background: linear-gradient(135deg, rgba(0, 219, 255, 0.24) 0%, rgba(0, 255, 117, 0.18) 100%);
			border: none;
			border-bottom: 1px solid var(--boxlang-border);
			border-radius: 24px 24px 0 0;
			color: white;
			font-weight: 600;
		}

		.btn-primary {
			background: linear-gradient(135deg, var(--boxlang-primary) 0%, var(--boxlang-secondary) 100%);
			border-color: transparent;
			color: #03222c;
			font-weight: 600;
			transition: all 0.3s ease;
			box-shadow: 0 12px 24px rgba(0, 219, 255, 0.18);
		}

		.btn-primary:hover {
			background: linear-gradient(135deg, #27e4ff 0%, #3fff9a 100%);
			border-color: transparent;
			transform: translateY(-2px);
		}

		.result-box {
			background: rgba(0, 0, 0, 0.18);
			border-left: 4px solid var(--boxlang-primary);
			border-radius: 8px;
			padding: 1.5rem;
			margin-top: 1rem;
		}

		.result-box pre {
			background: #02141b;
			color: #f8f8f2;
			padding: 1rem;
			border-radius: 8px;
			overflow-x: auto;
		}

		.spinner-border {
			color: var(--boxlang-primary);
		}

		.badge-accent {
			background: linear-gradient(135deg, rgba(0, 219, 255, 0.24), rgba(0, 255, 117, 0.28));
			border: 1px solid rgba(0, 255, 117, 0.3);
			color: var(--boxlang-text);
			padding: 0.55rem 0.9rem;
		}

		.server-card {
			background: var(--boxlang-surface-strong);
			border: 1px solid var(--boxlang-border);
			border-radius: 20px;
			padding: 1.5rem;
			margin-bottom: 1rem;
			height: 100%;
			box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
		}

		.stat-item {
			text-align: center;
			padding: 1rem;
			background: rgba(255, 255, 255, 0.03);
			border: 1px solid rgba(255, 255, 255, 0.05);
			border-radius: 16px;
		}

		.stat-item h4 {
			color: var(--boxlang-secondary);
			font-weight: 700;
		}

		.stat-item p {
			color: var(--boxlang-text-muted);
			margin-bottom: 0;
		}

		.input-group-text {
			background: linear-gradient(135deg, rgba(0, 219, 255, 0.24) 0%, rgba(0, 255, 117, 0.24) 100%);
			border: none;
			color: white;
		}

		.form-control:focus {
			border-color: var(--boxlang-primary);
			box-shadow: 0 0 0 0.2rem rgba(0, 219, 255, 0.2);
		}

		.fade-in {
			animation: fadeIn 0.5s ease-in;
		}

		@keyframes fadeIn {
			from {
				opacity: 0;
				transform: translateY(10px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		.loading-bar {
			height: 3px;
			background: linear-gradient(90deg, var(--boxlang-primary), var(--boxlang-secondary));
			animation: loading 1.5s ease-in-out infinite;
		}

		@keyframes loading {
			0%, 100% { width: 0; }
			50% { width: 100%; }
		}

		.icon-box {
			display: flex;
			align-items: center;
			justify-content: center;
			width: 50px;
			height: 50px;
			background: linear-gradient(135deg, rgba(0, 219, 255, 0.22) 0%, rgba(0, 255, 117, 0.18) 100%);
			border: 1px solid rgba(255, 255, 255, 0.08);
			border-radius: 14px;
			color: white;
			font-size: 1.5rem;
		}

		.section-note {
			color: var(--boxlang-text-muted);
			margin-bottom: 0;
		}

		.server-header {
			display: flex;
			align-items: flex-start;
			justify-content: space-between;
			gap: 1rem;
			margin-bottom: 1rem;
		}

		.server-header h5 {
			color: var(--boxlang-text);
		}

		.endpoint-link {
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			margin-top: 1rem;
			padding: 0.8rem 1rem;
			border-radius: 14px;
			border: 1px solid var(--boxlang-border-strong);
			background: rgba(0, 255, 117, 0.08);
			color: var(--boxlang-glow);
			text-decoration: none;
			font-weight: 600;
			transition: transform 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
		}

		.endpoint-link:hover {
			transform: translateY(-1px);
			border-color: rgba(0, 219, 255, 0.44);
			background: rgba(0, 219, 255, 0.1);
			color: var(--boxlang-text);
		}

		.endpoint-text {
			display: block;
			margin-top: 0.75rem;
			color: var(--boxlang-text-muted);
			font-size: 0.85rem;
			word-break: break-all;
		}

		.status-badge {
			display: inline-flex;
			align-items: center;
			padding: 0.45rem 0.75rem;
			border-radius: 999px;
			background: rgba(0, 255, 117, 0.14);
			border: 1px solid rgba(0, 255, 117, 0.28);
			color: var(--boxlang-secondary);
			font-weight: 600;
			font-size: 0.8rem;
		}

		@media (max-width: 991.98px) {
			.hero-grid {
				grid-template-columns: 1fr;
			}

			.welcome-section h1 {
				max-width: none;
			}

			.hero-logo-panel {
				order: -1;
			}
		}

		@media (max-width: 767.98px) {
			.navbar-brand {
				gap: 0.65rem;
			}

			.navbar-brand img {
				height: 2rem;
			}

			.welcome-section {
				padding: 2rem;
			}

			.hero-logo-panel {
				padding: 1.5rem;
			}

			.brand-copy small {
				display: none;
			}
		}
	</style>
</head>
<bx:output>
<body>
	<nav class="navbar navbar-dark">
		<div class="container-fluid">
			<span class="navbar-brand">
				<img src="layouts/logo-gradient-light.svg" alt="BoxLang logo">
				<span class="brand-copy">
					<strong>ColdBox</strong>
					<small>MCP Server</small>
				</span>
			</span>
		</div>
	</nav>

	<div class="container-fluid py-5">
		<div class="row mb-5">
			<div class="col-lg-12">
				<div class="welcome-section">
					<div class="hero-grid">
						<div>
							<span class="hero-badge">
								<i class="bi bi-diagram-3-fill"></i> Model Context Protocol
							</span>
							<h1 class="display-4 mb-3">ColdBox MCP Server Running</h1>
						</div>
						<div class="hero-logo-panel">
							<img class="hero-logo" src="layouts/logo-gradient-light.svg" alt="BoxLang AI logo">
						</div>
					</div>
				</div>
			</div>
		</div>

		<!--- Collect MCP Server data --->
		<bx:set mcpServer     = mcpServer( "cbMCP" ) />
		<bx:set serverInfo    = mcpServer.getServerInfo() />
		<bx:set statsSummary  = mcpServer.getStatsSummary() />
		<bx:set tools         = mcpServer.listTools() />
		<bx:set resources     = mcpServer.listResources() />
		<bx:set prompts       = mcpServer.listPrompts() />
		<bx:set detailedStats = mcpServer.getStats() />

		<!--- ===== Server Identity + Stats Row ===== --->
		<div class="row g-4 mb-5">

			<!--- Server Identity Card --->
			<div class="col-lg-5">
				<div class="server-card h-100">
					<div class="server-header">
						<div>
							<h5 class="mb-1">
								<i class="bi bi-server me-2" style="color:var(--boxlang-primary)"></i>
								<bx:output>#mcpServer.getServerName()#</bx:output>
							</h5>
							<p class="text-muted small mb-0"><bx:output>#mcpServer.getDescription()#</bx:output></p>
						</div>
						<span class="status-badge">
							<i class="bi bi-check-circle-fill me-1"></i> Active
						</span>
					</div>

					<div class="row g-2 mt-2">
						<div class="col-6">
							<div class="stat-item">
								<h4><bx:output>#tools.len()#</bx:output></h4>
								<p><i class="bi bi-tools me-1"></i>Tools</p>
							</div>
						</div>
						<div class="col-6">
							<div class="stat-item">
								<h4><bx:output>#resources.len()#</bx:output></h4>
								<p><i class="bi bi-folder2 me-1"></i>Resources</p>
							</div>
						</div>
						<div class="col-6">
							<div class="stat-item">
								<h4><bx:output>#prompts.len()#</bx:output></h4>
								<p><i class="bi bi-chat-text me-1"></i>Prompts</p>
							</div>
						</div>
						<div class="col-6">
							<div class="stat-item">
								<h4 class="text-truncate" style="font-size:0.85rem">
									<bx:output>#serverInfo.protocolVersion ?: "2024-11-05"#</bx:output>
								</h4>
								<p><i class="bi bi-layers me-1"></i>Protocol</p>
							</div>
						</div>
					</div>

					<div class="mt-3 d-flex flex-wrap gap-2 align-items-center">
						<span class="badge badge-accent">
							<i class="bi bi-tag me-1"></i>v<bx:output>#mcpServer.getVersion()#</bx:output>
						</span>
						<bx:if mcpServer.hasBasicAuth()>
							<span class="badge badge-accent">
								<i class="bi bi-lock-fill me-1"></i>Basic Auth
							</span>
						</bx:if>
						<bx:if mcpServer.hasApiKeyProvider()>
							<span class="badge badge-accent">
								<i class="bi bi-key-fill me-1"></i>API Key Auth
							</span>
						</bx:if>
						<bx:if mcpServer.isStatsEnabled()>
							<span class="badge badge-accent">
								<i class="bi bi-bar-chart-fill me-1"></i>Stats On
							</span>
						</bx:if>
					</div>

					<a href="/cbmcp" class="endpoint-link">
						<i class="bi bi-link-45deg"></i> MCP Endpoint
						<code class="endpoint-text">/cbmcp</code>
					</a>
				</div>
			</div>

			<!--- Stats Counters --->
			<div class="col-lg-7">
				<div class="row g-3 h-100">
					<div class="col-sm-6">
						<div class="server-card h-100 text-center">
							<div class="icon-box mx-auto mb-3">
								<i class="bi bi-arrow-left-right"></i>
							</div>
							<h3 style="color:var(--boxlang-primary)">
								<bx:output>#statsSummary.totalRequests#</bx:output>
							</h3>
							<p class="text-muted mb-1">Total Requests</p>
							<small class="text-muted">
								<i class="bi bi-check-lg" style="color:var(--boxlang-secondary)"></i>
								<bx:output>#numberFormat( statsSummary.successRate, "0.0" )#</bx:output>% success
							</small>
						</div>
					</div>
					<div class="col-sm-6">
						<div class="server-card h-100 text-center">
							<div class="icon-box mx-auto mb-3">
								<i class="bi bi-lightning-charge"></i>
							</div>
							<h3 style="color:var(--boxlang-secondary)">
								<bx:output>#numberFormat( statsSummary.avgResponseTime, "0" )#</bx:output>
								<small style="font-size:0.45em; vertical-align:middle"> ms</small>
							</h3>
							<p class="text-muted mb-1">Avg Response Time</p>
							<small class="text-muted">
								<i class="bi bi-clock me-1"></i>Up
								<bx:output>#numberFormat( statsSummary.uptime / 1000 / 60, "0" )#</bx:output>m
							</small>
						</div>
					</div>
					<div class="col-sm-6">
						<div class="server-card h-100 text-center">
							<div class="icon-box mx-auto mb-3">
								<i class="bi bi-tools"></i>
							</div>
							<h3 style="color:var(--boxlang-glow)">
								<bx:output>#statsSummary.totalToolInvocations#</bx:output>
							</h3>
							<p class="text-muted mb-1">Tool Invocations</p>
							<small class="text-muted">
								<i class="bi bi-collection me-1"></i>
								<bx:output>#statsSummary.totalResourceReads#</bx:output> resource reads
							</small>
						</div>
					</div>
					<div class="col-sm-6">
						<div class="server-card h-100 text-center">
							<div class="icon-box mx-auto mb-3"
								style="background:linear-gradient(135deg,rgba(255,80,80,0.18),rgba(255,140,0,0.14))">
								<i class="bi bi-exclamation-triangle"></i>
							</div>
							<h3 style="color:<bx:output>#statsSummary.totalErrors GT 0 ? '##ff6b6b' : 'var(--boxlang-secondary)'#</bx:output>">
								<bx:output>#statsSummary.totalErrors#</bx:output>
							</h3>
							<p class="text-muted mb-1">Errors</p>
							<bx:if len( statsSummary.lastRequestAt )>
								<small class="text-muted">
									<i class="bi bi-clock-history me-1"></i>Last:
									<bx:output>#timeFormat( statsSummary.lastRequestAt, "HH:mm:ss" )#</bx:output>
								</small>
							</bx:if>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!--- ===== Tools Section ===== --->
		<bx:if tools.len() GT 0>
			<div class="row mb-3">
				<div class="col-12">
					<h4 class="mb-0" style="color:var(--boxlang-primary)">
						<i class="bi bi-tools me-2"></i>Registered Tools
						<span class="badge badge-accent ms-2" style="font-size:0.7rem;vertical-align:middle">
							<bx:output>#tools.len()#</bx:output>
						</span>
					</h4>
					<p class="section-note small mt-1">All tools exposed via the MCP endpoint</p>
				</div>
			</div>
			<div class="row g-3 mb-5">
				<bx:loop array="#tools#" item="tool">
					<div class="col-md-6 col-xl-4">
						<div class="server-card h-100">
							<div class="d-flex align-items-start gap-3 mb-2">
								<div class="icon-box flex-shrink-0" style="width:42px;height:42px;font-size:1.1rem">
									<i class="bi bi-braces"></i>
								</div>
								<div class="flex-grow-1 overflow-hidden">
									<h6 class="mb-0" style="color:var(--boxlang-primary);word-break:break-all">
										<bx:output>#tool.name#</bx:output>
									</h6>
									<bx:if structKeyExists( tool, "description" ) AND len( tool.description )>
										<p class="text-muted small mb-0 mt-1">
											<bx:output>#tool.description#</bx:output>
										</p>
									</bx:if>
								</div>
							</div>
							<!--- Parameters from inputSchema --->
							<bx:if structKeyExists( tool, "inputSchema" )
								AND structKeyExists( tool.inputSchema, "properties" )
								AND tool.inputSchema.properties.count() GT 0>
								<div class="mt-2 pt-2" style="border-top:1px solid rgba(255,255,255,0.06)">
									<small class="text-muted d-block mb-1">
										<i class="bi bi-list-ul me-1"></i>Parameters:
									</small>
									<bx:loop collection="#tool.inputSchema.properties#" item="paramName">
										<bx:set paramDef = tool.inputSchema.properties[ paramName ] />
										<span class="badge badge-accent me-1 mb-1" style="font-size:0.68rem">
											<bx:output>#paramName#</bx:output>
											<bx:if structKeyExists( paramDef, "type" )>
												<span class="ms-1 opacity-60">
													<bx:output>#paramDef.type#</bx:output>
												</span>
											</bx:if>
											<bx:if structKeyExists( tool.inputSchema, "required" )
												AND isArray( tool.inputSchema.required )
												AND tool.inputSchema.required.findNoCase( paramName ) GT 0>
												<i class="bi bi-asterisk ms-1" title="required" style="font-size:0.5rem"></i>
											</bx:if>
										</span>
									</bx:loop>
								</div>
							<bx:else>
								<small class="text-muted">
									<i class="bi bi-dash-circle me-1"></i>No parameters
								</small>
							</bx:if>
						</div>
					</div>
				</bx:loop>
			</div>
		</bx:if>

		<!--- ===== Resources Section ===== --->
		<bx:if resources.len() GT 0>
			<div class="row mb-3">
				<div class="col-12">
					<h4 class="mb-0" style="color:var(--boxlang-primary)">
						<i class="bi bi-folder2-open me-2"></i>Resources
						<span class="badge badge-accent ms-2" style="font-size:0.7rem;vertical-align:middle">
							<bx:output>#resources.len()#</bx:output>
						</span>
					</h4>
				</div>
			</div>
			<div class="row g-3 mb-5">
				<bx:loop array="#resources#" item="resource">
					<div class="col-md-6 col-xl-4">
						<div class="server-card h-100">
							<div class="d-flex align-items-center gap-3">
								<div class="icon-box flex-shrink-0" style="width:42px;height:42px;font-size:1.1rem">
									<i class="bi bi-file-earmark-text"></i>
								</div>
								<div class="overflow-hidden">
									<h6 class="mb-0 text-truncate" style="color:var(--boxlang-secondary)">
										<bx:output>#resource.name ?: resource.uri#</bx:output>
									</h6>
									<small class="text-muted text-truncate d-block">
										<bx:output>#resource.uri#</bx:output>
									</small>
									<bx:if structKeyExists( resource, "mimeType" ) AND len( resource.mimeType )>
										<span class="badge badge-accent mt-1" style="font-size:0.65rem">
											<bx:output>#resource.mimeType#</bx:output>
										</span>
									</bx:if>
								</div>
							</div>
						</div>
					</div>
				</bx:loop>
			</div>
		</bx:if>

		<!--- ===== Prompts Section ===== --->
		<bx:if prompts.len() GT 0>
			<div class="row mb-3">
				<div class="col-12">
					<h4 class="mb-0" style="color:var(--boxlang-primary)">
						<i class="bi bi-chat-square-text me-2"></i>Prompts
						<span class="badge badge-accent ms-2" style="font-size:0.7rem;vertical-align:middle">
							<bx:output>#prompts.len()#</bx:output>
						</span>
					</h4>
				</div>
			</div>
			<div class="row g-3 mb-5">
				<bx:loop array="#prompts#" item="prompt">
					<div class="col-md-6 col-xl-4">
						<div class="server-card h-100">
							<div class="d-flex align-items-start gap-3">
								<div class="icon-box flex-shrink-0" style="width:42px;height:42px;font-size:1.1rem">
									<i class="bi bi-chat-text"></i>
								</div>
								<div>
									<h6 class="mb-0" style="color:var(--boxlang-secondary)">
										<bx:output>#prompt.name#</bx:output>
									</h6>
									<bx:if structKeyExists( prompt, "description" ) AND len( prompt.description )>
										<p class="text-muted small mb-0 mt-1">
											<bx:output>#prompt.description#</bx:output>
										</p>
									</bx:if>
									<bx:if structKeyExists( prompt, "arguments" ) AND isArray( prompt.arguments ) AND prompt.arguments.len() GT 0>
										<div class="mt-2">
											<bx:loop array="#prompt.arguments#" item="arg">
												<span class="badge badge-accent me-1" style="font-size:0.68rem">
													<bx:output>#arg.name#</bx:output>
												</span>
											</bx:loop>
										</div>
									</bx:if>
								</div>
							</div>
						</div>
					</div>
				</bx:loop>
			</div>
		</bx:if>

		<!--- ===== Detailed Stats (only when there's data) ===== --->
		<bx:if detailedStats.requests.total GT 0>
			<div class="row mb-3">
				<div class="col-12">
					<h4 class="mb-0" style="color:var(--boxlang-primary)">
						<i class="bi bi-bar-chart-line me-2"></i>Request Breakdown
					</h4>
					<p class="section-note small mt-1">Live request and tool invocation metrics</p>
				</div>
			</div>
			<div class="row g-4 mb-5">

				<!--- Requests by Method --->
				<div class="col-lg-6">
					<div class="server-card h-100">
						<h6 class="mb-3" style="color:var(--boxlang-glow)">
							<i class="bi bi-list-ul me-2"></i>By JSON-RPC Method
						</h6>
						<bx:if detailedStats.requests.byMethod.count() GT 0>
							<bx:loop collection="#detailedStats.requests.byMethod#" item="method">
								<bx:set methodCount = detailedStats.requests.byMethod[ method ] />
								<bx:set pct = numberFormat( methodCount / detailedStats.requests.total * 100, "0" ) />
								<div class="d-flex justify-content-between align-items-center mb-1">
									<code style="color:var(--boxlang-primary);font-size:0.83rem">
										<bx:output>#method#</bx:output>
									</code>
									<span class="badge badge-accent">
										<bx:output>#methodCount#</bx:output> calls
									</span>
								</div>
								<div class="progress mb-3" style="height:5px;background:rgba(255,255,255,0.07);border-radius:4px">
									<div class="progress-bar"
										style="width:#pct#%;background:linear-gradient(90deg,var(--boxlang-primary),var(--boxlang-secondary));border-radius:4px">
									</div>
								</div>
							</bx:loop>
						<bx:else>
							<p class="text-muted small">No method data yet.</p>
						</bx:if>

						<div class="mt-3 pt-3" style="border-top:1px solid rgba(255,255,255,0.06)">
							<div class="row g-2 text-center">
								<div class="col-4">
									<small class="text-muted d-block">Min</small>
									<strong style="color:var(--boxlang-text)">
										<bx:output>#numberFormat( detailedStats.requests.minResponseTime, "0" )#</bx:output>ms
									</strong>
								</div>
								<div class="col-4">
									<small class="text-muted d-block">Avg</small>
									<strong style="color:var(--boxlang-secondary)">
										<bx:output>#numberFormat( detailedStats.requests.avgResponseTime, "0" )#</bx:output>ms
									</strong>
								</div>
								<div class="col-4">
									<small class="text-muted d-block">Max</small>
									<strong style="color:var(--boxlang-text)">
										<bx:output>#numberFormat( detailedStats.requests.maxResponseTime, "0" )#</bx:output>ms
									</strong>
								</div>
							</div>
						</div>
					</div>
				</div>

				<!--- Tool Invocations --->
				<div class="col-lg-6">
					<div class="server-card h-100">
						<h6 class="mb-3" style="color:var(--boxlang-glow)">
							<i class="bi bi-tools me-2"></i>Tool Invocations
						</h6>
						<bx:if detailedStats.tools.byTool.count() GT 0>
							<bx:loop collection="#detailedStats.tools.byTool#" item="toolName">
								<bx:set toolData = detailedStats.tools.byTool[ toolName ] />
								<bx:set totalInvocations = max( detailedStats.tools.totalInvocations, 1 ) />
								<bx:set pct = numberFormat( toolData.count / totalInvocations * 100, "0" ) />
								<div class="d-flex justify-content-between align-items-center mb-1">
									<code style="color:var(--boxlang-secondary);font-size:0.83rem">
										<bx:output>#toolName#</bx:output>
									</code>
									<div class="text-end">
										<span class="badge badge-accent me-1">
											<bx:output>#toolData.count#</bx:output>×
										</span>
										<small class="text-muted">
											<bx:output>#numberFormat( toolData.avgTime, "0" )#</bx:output>ms avg
										</small>
									</div>
								</div>
								<div class="progress mb-3" style="height:5px;background:rgba(255,255,255,0.07);border-radius:4px">
									<div class="progress-bar"
										style="width:#pct#%;background:linear-gradient(90deg,var(--boxlang-secondary),var(--boxlang-glow));border-radius:4px">
									</div>
								</div>
							</bx:loop>

							<div class="mt-3 pt-3" style="border-top:1px solid rgba(255,255,255,0.06)">
								<div class="row g-2 text-center">
									<div class="col-4">
										<small class="text-muted d-block">Min</small>
										<strong style="color:var(--boxlang-text)">
											<bx:output>#numberFormat( detailedStats.tools.minExecutionTime, "0" )#</bx:output>ms
										</strong>
									</div>
									<div class="col-4">
										<small class="text-muted d-block">Avg</small>
										<strong style="color:var(--boxlang-secondary)">
											<bx:output>#numberFormat( detailedStats.tools.avgExecutionTime, "0" )#</bx:output>ms
										</strong>
									</div>
									<div class="col-4">
										<small class="text-muted d-block">Max</small>
										<strong style="color:var(--boxlang-text)">
											<bx:output>#numberFormat( detailedStats.tools.maxExecutionTime, "0" )#</bx:output>ms
										</strong>
									</div>
								</div>
							</div>
						<bx:else>
							<p class="text-muted small">No tool invocations yet.</p>
						</bx:if>
					</div>
				</div>

			</div>
		</bx:if>

	</div>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</bx:output>
</html>
