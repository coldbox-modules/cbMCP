class extends="coldbox.system.testing.BaseTestCase" {

	/*********************************** LIFE CYCLE Methods ***********************************/

	function beforeAll() {
		super.beforeAll()
		setup()
	}

	function afterAll() {
		super.afterAll()
	}

	/*********************************** BDD SUITES ***********************************/

	function run() {
		describe( "LogBoxTools", function() {

			beforeEach( function( currentSpec ) {
				variables.tool = getInstance( "LogBoxTools@cbMCP" )
			} )

			// --- get_logbox_info ---
			it( "can get logbox general info", function() {
				var result = tool.get_logbox_info()
				expect( result ).toBeStruct()
				expect( result ).toHaveKey( "version" )
				expect( result ).toHaveKey( "logBoxID" )
				expect( result ).toHaveKey( "loggers" )
				expect( result ).toHaveKey( "appenders" )
				expect( result.version ).notToBeEmpty()
				expect( result.logBoxID ).notToBeEmpty()
			} )

			it( "loggers and appenders fields are sorted arrays of strings", function() {
				var result = tool.get_logbox_info()
				expect( result.loggers ).toBeArray()
				expect( result.appenders ).toBeArray()
				expect( result.loggers.len() ).toBeGT( 0 )
				result.loggers.each( ( name ) => {
					expect( name ).toBeString()
				} )
			} )

			// --- get_loggers ---
			it( "can get all registered loggers", function() {
				var result = tool.get_loggers()
				expect( result ).toBeArray()
				expect( result.len() ).toBeGT( 0 )
			} )

			it( "logger entries have expected keys", function() {
				var result = tool.get_loggers()
				var first  = result[ 1 ]
				expect( first ).toHaveKey( "category" )
				expect( first ).toHaveKey( "levelMin" )
				expect( first ).toHaveKey( "levelMax" )
				expect( first ).toHaveKey( "canDebug" )
				expect( first ).toHaveKey( "canInfo" )
				expect( first ).toHaveKey( "canWarn" )
				expect( first ).toHaveKey( "canError" )
				expect( first ).toHaveKey( "canFatal" )
				expect( first ).toHaveKey( "appenders" )
				expect( first.category ).toBeString()
				expect( first.appenders ).toBeArray()
			} )

			// --- get_logger ---
			it( "can get details for the ROOT logger by category name", function() {
				var result = tool.get_logger( "ROOT" )
				expect( result ).toBeStruct()
				expect( result ).toHaveKey( "category" )
				expect( result ).toHaveKey( "levelMin" )
				expect( result ).toHaveKey( "levelMax" )
				expect( result ).toHaveKey( "appenders" )
				expect( result.category ).toBe( "ROOT" )
			} )

			it( "returns an error string for a non-existent logger category", function() {
				var result = tool.get_logger( "__nonExistentCategory__XYZ__" )
				expect( result ).toBeString()
				expect( result ).toInclude( "No logger found" )
			} )

			// --- get_appenders ---
			it( "can get all registered appenders", function() {
				var result = tool.get_appenders()
				expect( result ).toBeArray()
				expect( result.len() ).toBeGT( 0 )
			} )

			it( "appender entries have expected keys", function() {
				var result = tool.get_appenders()
				var first  = result[ 1 ]
				expect( first ).toHaveKey( "name" )
				expect( first ).toHaveKey( "class" )
				expect( first ).toHaveKey( "levelMin" )
				expect( first ).toHaveKey( "levelMax" )
				expect( first ).toHaveKey( "initialized" )
				expect( first.name ).toBeString()
				expect( first.class ).toBeString()
				expect( first.initialized ).toBeBoolean()
			} )

			it( "appender names match logbox info appender list", function() {
				var info          = tool.get_logbox_info()
				var appenders     = tool.get_appenders()
				var appenderNames = appenders.map( ( a ) => a.name ).sort( "textnocase" )
				expect( appenderNames ).toBe( info.appenders )
			} )

			// --- get_root_logger ---
			it( "can get the root logger", function() {
				var result = tool.get_root_logger()
				expect( result ).toBeStruct()
				expect( result ).toHaveKey( "category" )
				expect( result ).toHaveKey( "levelMin" )
				expect( result ).toHaveKey( "levelMax" )
				expect( result ).toHaveKey( "canDebug" )
				expect( result ).toHaveKey( "appenders" )
				expect( result.category ).toBe( "ROOT" )
			} )

			it( "root logger matches get_logger( ROOT ) result", function() {
				var fromRoot   = tool.get_root_logger()
				var fromLookup = tool.get_logger( "ROOT" )
				expect( fromRoot.levelMin ).toBe( fromLookup.levelMin )
				expect( fromRoot.levelMax ).toBe( fromLookup.levelMax )
				expect( fromRoot.appenders ).toBe( fromLookup.appenders )
			} )

			// --- read_log_entries ---
			it( "can read log entries from all file-based appenders", function() {
				// Write something to the log so there is at least one entry
				application.cbController.getLogBox().getRootLogger().info( "cbMCP test: read_log_entries probe" )
				// Give the async queue a moment to flush
				sleep( 300 )
				var result = tool.read_log_entries()
				expect( result ).toBeArray()
				expect( result.len() ).toBeGT( 0 )
			} )

			it( "read_log_entries result items have expected keys", function() {
				var result = tool.read_log_entries()
				expect( result ).toBeArray()
				var first = result[ 1 ]
				expect( first ).toHaveKey( "appenderName" )
				expect( first ).toHaveKey( "logFile" )
				expect( first ).toHaveKey( "entries" )
				expect( first.appenderName ).toBeString()
				expect( first.logFile ).toBeString()
				expect( first.entries ).toBeArray()
			} )

			it( "read_log_entries entries have expected log line keys", function() {
				application.cbController.getLogBox().getRootLogger().warn( "cbMCP test: entry key probe" )
				sleep( 300 )
				var result = tool.read_log_entries()
				var entries = result[ 1 ].entries
				expect( entries.len() ).toBeGT( 0 )
				var entry = entries[ entries.len() ]
				expect( entry ).toHaveKey( "severity" )
				expect( entry ).toHaveKey( "appender" )
				expect( entry ).toHaveKey( "date" )
				expect( entry ).toHaveKey( "time" )
				expect( entry ).toHaveKey( "category" )
				expect( entry ).toHaveKey( "message" )
				expect( entry.severity ).toBeString()
				expect( entry.severity ).notToBeEmpty()
			} )

			it( "read_log_entries respects the limit parameter", function() {
				var result  = tool.read_log_entries( limit = 2 )
				var entries = result[ 1 ].entries
				expect( entries.len() ).toBeLTE( 2 )
			} )

			it( "read_log_entries returns error string for unknown appender name", function() {
				var result = tool.read_log_entries( appenderName = "__nonExistentAppender__XYZ__" )
				expect( result ).toBeString()
				expect( result ).toInclude( "No file-based appender found" )
			} )

			it( "read_log_entries skips non-file appenders (myConsole)", function() {
				// myConsole is a ConsoleAppender — should not appear in results
				var result = tool.read_log_entries()
				expect( result ).toBeArray()
				var names = result.map( ( r ) => r.appenderName )
				expect( names ).notToInclude( "myConsole" )
			} )

			// --- get_last_error ---
			it( "can get the last error from file-based appenders", function() {
				application.cbController.getLogBox().getRootLogger().error( "cbMCP test: last error probe" )
				sleep( 300 )
				var result = tool.get_last_error()
				expect( result ).toBeArray()
				expect( result.len() ).toBeGT( 0 )
			} )

			it( "get_last_error result items have expected keys", function() {
				var result = tool.get_last_error()
				var first  = result[ 1 ]
				expect( first ).toHaveKey( "appenderName" )
				expect( first ).toHaveKey( "logFile" )
				expect( first ).toHaveKey( "entry" )
				expect( first ).toHaveKey( "note" )
			} )

			it( "get_last_error returns an ERROR or FATAL entry after logging one", function() {
				application.cbController.getLogBox().getRootLogger().error( "cbMCP test: verifiable error entry" )
				sleep( 300 )
				var result = tool.get_last_error()
				var entry  = result[ 1 ].entry
				expect( entry ).toBeStruct()
				expect( entry ).toHaveKey( "severity" )
				expect( entry.severity ).toBeIn( [ "ERROR", "FATAL" ] )
			} )

			it( "get_last_error entry message matches logged message", function() {
				var marker = "cbMCP test marker #createUUID()#"
				application.cbController.getLogBox().getRootLogger().error( marker )
				sleep( 300 )
				var result = tool.get_last_error()
				var entry  = result[ 1 ].entry
				expect( entry.message ).toInclude( marker )
			} )

			it( "get_last_error returns error string for unknown appender name", function() {
				var result = tool.get_last_error( appenderName = "__nonExistentAppender__XYZ__" )
				expect( result ).toBeString()
				expect( result ).toInclude( "No file-based appender found" )
			} )

		} )
	}

}
