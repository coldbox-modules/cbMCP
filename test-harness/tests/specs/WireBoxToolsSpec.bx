class extends="coldbox.system.testing.BaseTestCase" {

	/*********************************** LIFE CYCLE Methods ***********************************/

	function beforeAll() {
		super.beforeAll()
		setup()
	}

	function afterAll() {
		super.afterAll()
	}

	/*********************************** BDD SUITES ***********************************/

	function run() {
		describe( "WireBoxTools", function() {

			beforeEach( function( currentSpec ) {
				variables.tool = getInstance( "WireBoxTools@cbMCP" )
			} )

			it( "can get all WireBox mappings as JSON", function() {
				var result = tool.get_wirebox_mappings()
				expect( result ).toBeArray()
			} )

			it( "returns mapping entries with expected keys", function() {
				var result = tool.get_wirebox_mappings()
				expect( result.len() ).toBeGT( 0 )
				var first = result[ 1 ]
				expect( first ).toHaveKey( "name" )
				expect( first ).toHaveKey( "path" )
				expect( first ).toHaveKey( "type" )
				expect( first ).toHaveKey( "scope" )
				expect( first ).toHaveKey( "autowire" )
			} )

			// --- has_mapping ---
			it( "returns true for a known mapping", function() {
				var mappings = tool.get_wirebox_mappings()
				var result   = tool.has_mapping( mappings[ 1 ].name )
				expect( result ).toBeBoolean()
				expect( result ).toBeTrue()
			} )

			it( "returns false for a non-existent mapping", function() {
				var result = tool.has_mapping( "__NonExistentMapping__XYZ__" )
				expect( result ).toBeBoolean()
				expect( result ).toBeFalse()
			} )

			// --- get_mapping ---
			it( "can get details for a specific mapping by name", function() {
				var mappings = tool.get_wirebox_mappings()
				var result   = tool.get_mapping( mappings[ 1 ].name )
				expect( result ).toBeStruct()
				expect( result ).toHaveKey( "name" )
				expect( result ).toHaveKey( "path" )
				expect( result ).toHaveKey( "type" )
				expect( result ).toHaveKey( "scope" )
				expect( result ).toHaveKey( "autowire" )
			} )

			it( "returns an error string for a non-existent mapping", function() {
				var result = tool.get_mapping( "__NonExistentMapping__XYZ__" )
				expect( result ).toBeString()
				expect( result ).toInclude( "No WireBox mapping found" )
			} )

		} )
	}

}
